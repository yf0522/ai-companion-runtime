# Copy values into a secret manager or deployment environment. Do not deploy
# this file or reuse any placeholder value.
APP_ENV=production
PUBLIC_BASE_URL=https://companion.example.com
PUBLIC_API_URL=https://companion.example.com
PUBLIC_WS_URL=wss://companion.example.com
REQUIRE_TLS=true
CORS_ALLOWED_ORIGINS=https://family.companion.example.com,https://ops.companion.example.com

DATABASE_URL=postgresql+asyncpg://companion:REPLACE@postgres:5432/companion
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=REPLACE
CELERY_BROKER_URL=redis://redis:6379/1
RATE_LIMIT_FAILURE_MODE=deny
ALLOW_EPHEMERAL_SESSIONS=false

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=REPLACE
MINIO_SECRET_KEY=REPLACE
MINIO_SECURE=true

JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

EXPECTED_MIGRATION_HEADS=f2a3b4c5d6e7
BACKUP_BUCKET=REPLACE
BACKUP_KMS_KEY_ID=REPLACE
EVIDENCE_MANIFEST_REQUIRED=true

NOTIFICATION_PROVIDER=signed_webhook
NOTIFICATION_OUTBOUND_URL=REPLACE_WITH_HTTPS_NOTIFICATION_ENDPOINT
NOTIFICATION_WEBHOOK_SECRET=REPLACE
ENABLE_CELERY_TASKS=true
DEVICE_IDENTITY_REQUIRED=true
CONTROLLED_ELDER_ENROLLMENT=true
PLATFORM_WORKER_HEARTBEAT_KEY=platform:worker:heartbeat
PLATFORM_WORKER_HEARTBEAT_MAX_AGE_SECONDS=120
ENABLE_PI_RUNTIME=true
PI_SIDECAR_URL=http://pi-sidecar:8787
# Required when ENABLE_PI_RUNTIME=true in production — shared by API + pi-sidecar tool bridge.
TOOL_BRIDGE_TOKEN=REPLACE_WITH_LONG_RANDOM_SHARED_SECRET

# mem0 OSS LTM engine (consent SoT stays Postgres). Empty/timeout → degrade, never lifecycle dump.
# Under MEM0_ENABLED, analyzer L3 lifecycle vectors are skipped; LTM recall is FC memory tool only.
MEM0_ENABLED=1
# MEM0_CONFIG_JSON={"llm":{"provider":"openai","config":{"model":"gpt-4o-mini","api_key":"REPLACE"}},"embedder":{"provider":"openai","config":{"model":"text-embedding-3-small","api_key":"REPLACE"}},"vector_store":{"provider":"pgvector","config":{"dbname":"companion","user":"companion","password":"REPLACE","host":"postgres","port":5432}}}

NEXT_PUBLIC_WS_URL=wss://companion.example.com
NEXT_PUBLIC_API_URL=https://companion.example.com
